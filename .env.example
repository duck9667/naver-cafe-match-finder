NAVER_CLIENT_ID=your_naver_api_client_id
NAVER_CLIENT_SECRET=your_naver_api_client_secret

# Slack bot 알림 (run.py / notify_slack.py 에서 사용)
# Slack App을 만들고 Bot Token User OAuth Scope에 chat:write, im:write를 추가한 뒤
# 워크스페이스에 설치해서 받은 토큰(xoxb-...)을 넣는다.
SLACK_BOT_TOKEN=xoxb-your-bot-token
# 알림 받을 사람들. Slack 유저 ID(U로 시작, DM으로 발송) 또는 채널 ID(C/G로 시작)를
# 쉼표로 여러 개 나열할 수 있다 — 친구를 추가하려면 여기에 user ID만 더하면 된다.
SLACK_RECIPIENTS=U0XXXXXXXXX,U0YYYYYYYYY

# 아래는 선택 항목 (기본값은 "모두의 풋살축구" 카페, 용산/도곡 매칭 검색)
# TARGET_CAFE=모두의 풋살축구
# SEARCH_QUERIES=용산 풋살,도곡 풋살,용산 풋살 매칭,도곡 풋살 매칭
# EXCLUDE_KEYWORDS=초청,매칭완료,매치완료,마감,용병,회원 모집,팀원 구합니다,양도
# REMOVE_FROM_TITLE=스타디움
